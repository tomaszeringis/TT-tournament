# Tournament Platform - Environment Configuration
# Copy this file to .env and adjust values for your environment.

# ---------------------------------------------------------------------------
# API / Backend
# ---------------------------------------------------------------------------
# Base URL used by the Streamlit frontend to reach the FastAPI backend.
# Default: http://localhost:8000
API_BASE_URL=http://localhost:8000

# Timeout for API requests in seconds.
# Default: 10
API_TIMEOUT_SECONDS=10

# Show debug details in error messages (for development only).
# In production, this should be False to avoid exposing sensitive information.
# Default: False
SHOW_DEBUG_DETAILS=False

# ---------------------------------------------------------------------------
# AI / Ollama
# ---------------------------------------------------------------------------
# Ollama model identifier used by the AI engine and rules assistant.
# Default: llama3:latest
OLLAMA_MODEL=llama3:latest

# ---------------------------------------------------------------------------
# Feature Flags (quick wins)
# ---------------------------------------------------------------------------
# Enable voice-based match entry (uses faster-whisper / SpeechRecognition).
# Default: True
ENABLE_VOICE_ENTRY=True

# Enable the AI rules assistant (RAG over tournament rule documents).
# Default: True
ENABLE_RULES_ASSISTANT=True

# Enable ranking intelligence features (AI-enhanced ranking insights).
# Default: True
ENABLE_RANKING_INTELLIGENCE=True

# Enable spoken confirmation prompts after voice actions.
# Default: False
ENABLE_SPOKEN_CONFIRMATION=False

# ---------------------------------------------------------------------------
# Speech / Audio
# ---------------------------------------------------------------------------
# Keep temporary audio files after transcription (useful for debugging).
# Default: False
KEEP_AUDIO_FILES=False

# Whisper model size for speech-to-text transcription.
# Options: tiny, base, small, medium, large-v3
# Smaller = faster, larger = more accurate.
# Default: base
SPEECH_MODEL_SIZE=base

# ---------------------------------------------------------------------------
# Voice Scorekeeper — ASR & Feature Flags
# ---------------------------------------------------------------------------
# ASR backend selection (default: faster_whisper). Options: faster_whisper, speechbrain, vosk
VOICE_ASR_BACKEND=faster_whisper
# Fallback ASR backend if the preferred backend is unavailable
VOICE_ASR_FALLBACK_BACKEND=faster_whisper
# faster-whisper model size. Options: tiny.en, base.en, small.en, medium.en, large-v3
VOICE_ASR_MODEL_SIZE=tiny.en
# Device for ASR model. Options: cpu, cuda, auto
VOICE_ASR_DEVICE=cpu
# Compute type. Options: int8, float16, float32
VOICE_ASR_COMPUTE_TYPE=int8
# Hugging Face token for model downloads (removes rate limits on Cloud)
HF_TOKEN=
# Vosk model directory (only if VOICE_ASR_BACKEND=vosk)
VOICE_ASR_VOSK_MODEL_PATH=model
# Voice vocabulary file (JSON, optional)
VOICE_ASR_VOCAB_FILE=
# Require confirmation for score-setting commands (true/false)
VOICE_ENABLE_CONFIRMATION=true
# Enable noise gate (true/false)
VOICE_ENABLE_NOISE_FILTERING=false
# RMS noise threshold (0.0 = disabled)
VOICE_NOISE_THRESHOLD=0.0
# Strict mode: require explicit phrases/confirmation in noisy venues (true/false)
VOICE_STRICT_MODE=false
# Enable verbose voice event logging + debug screen (true/false)
VOICE_DEBUG_EVENTS=false
# Enable spoken confirmation prompts after voice actions (true/false)
VOICE_ENABLE_SPOKEN_CONFIRMATION=false
# Enable LLM-assisted command interpretation fallback (true/false)
VOICE_ENABLE_LLM_INTERPRETER=false
# Keep temporary audio files after transcription (useful for debugging)
KEEP_AUDIO_FILES=false
# Opt-in dataset recording (true/false)
VOICE_DATASET_OPT_IN=false
# Enable sound cues for scoring events (browser Web Audio)
SCORE_ENABLE_SOUNDS=false

# ---------------------------------------------------------------------------
# Multimodal AI Data Storage
# ---------------------------------------------------------------------------
# Root directory for all multimodal AI data (datasets, features, models)
# Default: ../tt_ai_data (relative to tournament_platform/)
TT_DATA_ROOT=../tt_ai_data

# Directory for raw downloaded datasets
TT_RAW_DATA_DIR=../tt_ai_data/raw

# Directory for processed datasets
TT_PROCESSED_DATA_DIR=../tt_ai_data/processed

# Directory for extracted features
TT_FEATURES_DIR=../tt_ai_data/features

# Directory for trained models
TT_MODELS_DIR=../tt_ai_data/models

# Directory for cache files
TT_CACHE_DIR=../tt_ai_data/cache

# Directory for dataset manifests
TT_MANIFESTS_DIR=../tt_ai_data/manifests

# Directory for multimodal ChromaDB indexes
TT_MULTIMODAL_CHROMA_DIR=../tt_ai_data/indexes/chroma_multimodal
