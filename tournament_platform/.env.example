# =============================================================================
# Tournament Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Tournament Platform
APP_VERSION=1.0.0
DEBUG=false

# -----------------------------------------------------------------------------
# FastAPI Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite URL (relative to project root) or full PostgreSQL/MySQL URL
DATABASE_URL=sqlite:///data/tournament.db

# -----------------------------------------------------------------------------
# Ollama LLM
# -----------------------------------------------------------------------------
# Host running Ollama (usually localhost for dev)
OLLAMA_HOST=http://localhost:11434
# Default chat model
OLLAMA_MODEL=llama3:latest
# Embedding model for RAG
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Embedding endpoint (usually same host + /api/embeddings)
OLLAMA_EMBEDDING_URL=http://localhost:11434/api/embeddings

# -----------------------------------------------------------------------------
# ChromaDB / RAG
# -----------------------------------------------------------------------------
# Path to persistent ChromaDB storage (relative to project root)
CHROMA_DB_PATH=data/chroma_db

# -----------------------------------------------------------------------------
# Whisper (Speech-to-Text)
# -----------------------------------------------------------------------------
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=base
# Device: cpu or cuda
WHISPER_DEVICE=cpu
# Compute type: int8, float16, float32
WHISPER_COMPUTE_TYPE=int8

# -----------------------------------------------------------------------------
# TTS (Text-to-Speech)
# -----------------------------------------------------------------------------
TTS_SAMPLE_RATE=24000
TTS_CHUNK_SIZE=1024

# -----------------------------------------------------------------------------
# Audio Capture
# -----------------------------------------------------------------------------
# pyaudio.paInt16 = 8
AUDIO_FORMAT=8
AUDIO_CHANNELS=1
AUDIO_RATE=16000
AUDIO_CHUNK=1024
# RMS threshold for silence detection
AUDIO_SILENCE_THRESHOLD=500
# Minimum silence duration in seconds
AUDIO_MIN_SILENCE_DURATION=1.0

# -----------------------------------------------------------------------------
# Microsoft Teams Webhook (notifications)
# -----------------------------------------------------------------------------
# Incoming webhook URL from Teams channel connector
# Leave empty to disable Teams notifications
TEAMS_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Azure AD / Microsoft Graph (Calendar integration)
# -----------------------------------------------------------------------------
# Register an app in Azure AD to get these values.
# See: https://learn.microsoft.com/en-us/graph/auth-overview
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# -----------------------------------------------------------------------------
# Streamlit Authenticator
# -----------------------------------------------------------------------------
# These are used for cookie-based auth in Streamlit.
# For production, use strong random values.
AUTH_COOKIE_NAME=tt_auth_cookie
AUTH_COOKIE_KEY=change_me_to_a_random_secret_key
AUTH_COOKIE_EXPIRY_DAYS=30

# -----------------------------------------------------------------------------
# Tournament defaults
# -----------------------------------------------------------------------------
# Starting ELO rating for new players
DEFAULT_PLAYER_RATING=1200

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_DIR=logs
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Semantic Kernel (AI Assistant page)
# -----------------------------------------------------------------------------
SEMANTIC_KERNEL_OLLAMA_HOST=http://localhost:11434
SEMANTIC_KERNEL_MODEL_ID=llama3.1:latest
